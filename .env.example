# Copy this file to .env and fill in the values.
# Never commit the real .env file.

# Generate a strong secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# SQLite (default, no extra setup):
# DATABASE_URL=sqlite:///schoolbell.db
#
# PostgreSQL (recommended for multi-user production):
# DATABASE_URL=postgresql://user:password@localhost/schoolbell_db

# Anthropic API key — required for question generation and cheatsheets
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# 'production' on the server, 'development' locally
FLASK_CONFIG=development
